# Required Slack settings
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_CHANNEL_ID=CHANNEL_ID
SLACK_CHANNEL_NAME=channel-name

# Required location lookup setting
MUMEMO_NOMINATIM_USER_AGENT=Project Name & Your Name

# Optional Nominatim settings
MUMEMO_NOMINATIM_EMAIL=you@example.com
MUMEMO_NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org/search
MUMEMO_NOMINATIM_TIMEOUT_SECONDS=10

# Optional Mumemo settings
MUMEMO_DATA_PATH=docs/data/memos.json
MUMEMO_SLACK_ASSET_DIR=docs/assets/slack
MUMEMO_SLACK_ASSET_URL_PREFIX=/assets/slack
MUMEMO_SLACK_ORIGINAL_ASSET_DIR=originals/slack
MUMEMO_GITHUB_REPO_URL=https://github.com/Nyanyan/Mumemo
MUMEMO_GITHUB_BRANCH=main
MUMEMO_DEFAULT_IMAGE=/website_icon_small.png
MUMEMO_SITE_BASE_URL=https://mumemo.nyanyan.dev
MUMEMO_ROUTE_BUILD_COMMAND=node scripts/build-route-pages.mjs
